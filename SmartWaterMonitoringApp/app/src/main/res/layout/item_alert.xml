<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:background="@drawable/card_glass_strong"
    android:layout_marginBottom="12dp">

    <!-- Alert Icon with Glow -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp">

        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:background="@drawable/glow_effect"/>

        <ImageView
            android:id="@+id/ivAlertIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="@color/polluted_red"/>

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Type Badge and Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvAlertType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 CRITICAL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/status_danger"
                android:paddingVertical="4dp"
                android:paddingHorizontal="10dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvAlertTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2 minutes ago"
                android:textSize="12sp"
                android:textColor="@color/text_hint"
                android:gravity="end"/>

        </LinearLayout>

        <!-- Alert Title -->
        <TextView
            android:id="@+id/tvAlertTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="pH Level Critical"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_dark"
            android:layout_marginBottom="4dp"/>

        <!-- Alert Message -->
        <TextView
            android:id="@+id/tvAlertMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="pH level has dropped below safe threshold"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_dark"
            android:layout_marginBottom="8dp"/>

        <!-- Threshold Info - Glass Badge -->
        <TextView
            android:id="@+id/tvAlertThreshold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Threshold: pH 6.5-8.5 | Current: 5.8"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:background="@drawable/card_glass"
            android:paddingVertical="6dp"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

</LinearLayout>
