<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Premium Dark Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_premium_dark"/>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Premium Gradient Header with Search -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_header"
                android:orientation="vertical"
                android:paddingBottom="20dp"
                android:elevation="8dp">

                <!-- Top Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌍 Community"
                        android:textSize="24sp"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"/>

                    <ImageButton
                        android:id="@+id/btnProfileIcon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:background="@drawable/card_glass"
                        android:padding="10dp"
                        app:tint="@android:color/white"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Profile"/>

                    <ImageButton
                        android:id="@+id/btnLogoutIcon"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@android:drawable/ic_lock_power_off"
                        android:background="@drawable/card_glass"
                        android:padding="10dp"
                        app:tint="@android:color/white"
                        android:contentDescription="Logout"/>

                </LinearLayout>

                <!-- Search/Filter Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_glass"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/text_hint"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search posts..."
                        android:textSize="15sp"
                        android:textColor="@color/text_hint"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Content Area with Pull-to-Refresh -->
            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/swipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ListView
                    android:id="@+id/lvCommunityPosts"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="0dp"
                    android:clipToPadding="false"
                    android:paddingTop="16dp"
                    android:paddingBottom="100dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:scrollbarStyle="outsideOverlay"/>

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <!-- Premium Floating Bottom Navigation -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp">

                <com.google.android.material.bottomnavigation.BottomNavigationView
                    android:id="@+id/bottom_navigation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_glass_strong"
                    android:elevation="0dp"
                    app:menu="@menu/bottom_nav_menu"
                    app:itemIconTint="@color/bottom_nav_color"
                    app:itemTextColor="@color/bottom_nav_color"
                    app:labelVisibilityMode="labeled"/>

            </FrameLayout>

        </LinearLayout>

        <!-- Premium FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNewPost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="24dp"
            android:layout_marginBottom="100dp"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="New Post"
            app:backgroundTint="@color/primary"
            app:tint="@android:color/white"
            app:fabSize="normal"
            app:elevation="8dp"/>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</FrameLayout>
