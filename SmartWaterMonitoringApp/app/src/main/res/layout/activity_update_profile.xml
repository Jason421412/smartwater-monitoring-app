<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Premium Dark Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_premium_dark"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Premium Gradient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/gradient_header"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:elevation="8dp">

            <ImageButton
                android:id="@+id/btnBackUpdateProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✏️ Edit Profile"
                android:textSize="22sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="8dp"/>

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Profile Picture Section - Glass Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_strong"
                    android:padding="24dp"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷 Profile Picture"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:layout_marginBottom="20dp"/>

                    <!-- Profile Picture with Glow -->
                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="150dp"
                            android:layout_height="150dp"
                            android:layout_gravity="center"
                            android:background="@drawable/glow_effect"/>

                        <LinearLayout
                            android:layout_width="130dp"
                            android:layout_height="130dp"
                            android:layout_gravity="center"
                            android:background="@drawable/avatar_circle"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/ivProfilePicture"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:src="@android:drawable/ic_menu_myplaces"
                                app:tint="@color/primary"/>

                        </LinearLayout>

                    </FrameLayout>

                    <!-- Change Profile Picture Button -->
                    <Button
                        android:id="@+id/btnChangeProfilePicture"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="📁 Change Picture"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:textAllCaps="false"
                        android:background="@drawable/card_glass"
                        android:paddingHorizontal="24dp"
                        android:stateListAnimator="@null"/>

                </LinearLayout>

                <!-- Edit Form - Glass Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_strong"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Personal Information"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary_dark"
                        android:layout_marginBottom="20dp"/>

                    <!-- Name Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full Name"
                        android:layout_marginBottom="16dp"
                        style="@style/ModernTextInput"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUpdateName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_primary_dark"
                            android:textColorHint="@color/text_hint"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Phone Number"
                        android:layout_marginBottom="24dp"
                        style="@style/ModernTextInput"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:hintTextColor="@color/primary"
                        app:startIconDrawable="@android:drawable/ic_menu_call"
                        app:startIconTint="@color/primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etUpdatePhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:textColor="@color/text_primary_dark"
                            android:textColorHint="@color/text_hint"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save Button - Gradient -->
                    <Button
                        android:id="@+id/btnSaveProfile"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="💾 SAVE CHANGES"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:textAllCaps="false"
                        android:background="@drawable/btn_gradient"
                        android:stateListAnimator="@null"/>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</FrameLayout>
