<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Premium Dark Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_premium_dark"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Premium Gradient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/gradient_header"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:elevation="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔔 Alerts"
                android:textSize="24sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <ImageButton
                android:id="@+id/btnProfileIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:background="@drawable/card_glass"
                android:padding="10dp"
                app:tint="@android:color/white"
                android:layout_marginEnd="8dp"
                android:contentDescription="Profile"/>

            <ImageButton
                android:id="@+id/btnLogoutIcon"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_lock_power_off"
                android:background="@drawable/card_glass"
                android:padding="10dp"
                app:tint="@android:color/white"
                android:contentDescription="Logout"/>

        </LinearLayout>

        <!-- Filter Chips - Glass -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <Button
                    android:id="@+id/btnFilterAll"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="All"
                    android:textSize="14sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/btn_gradient"
                    android:paddingHorizontal="20dp"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnFilterCritical"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="🚨 Critical"
                    android:textSize="14sp"
                    android:textColor="@color/polluted_red"
                    android:background="@drawable/card_glass"
                    android:paddingHorizontal="20dp"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnFilterWarning"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="⚠️ Warning"
                    android:textSize="14sp"
                    android:textColor="@color/moderate_orange"
                    android:background="@drawable/card_glass"
                    android:paddingHorizontal="20dp"
                    android:layout_marginEnd="10dp"
                    android:stateListAnimator="@null"/>

                <Button
                    android:id="@+id/btnFilterInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:text="ℹ️ Info"
                    android:textSize="14sp"
                    android:textColor="@color/primary"
                    android:background="@drawable/card_glass"
                    android:paddingHorizontal="20dp"
                    android:stateListAnimator="@null"/>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- Alerts List -->
        <ListView
            android:id="@+id/lvAlerts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:clipToPadding="false"
            android:padding="16dp"
            android:paddingBottom="80dp"/>

        <!-- Premium Bottom Navigation -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottom_navigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_glass_strong"
                android:elevation="0dp"
                app:menu="@menu/bottom_nav_menu"
                app:itemIconTint="@color/bottom_nav_color"
                app:itemTextColor="@color/bottom_nav_color"
                app:labelVisibilityMode="labeled"/>

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
