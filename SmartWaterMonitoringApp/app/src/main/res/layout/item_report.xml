<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/card_glass_strong"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <!-- Report Icon with Glow -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp">

            <View
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/glow_effect"/>

            <LinearLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@drawable/avatar_circle"
                android:gravity="center">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@android:drawable/ic_menu_report_image"
                    app:tint="@color/primary"/>

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReportTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pollution Report"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_dark"/>

            <TextView
                android:id="@+id/tvReportTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 2024-12-15 10:30 AM"
                android:textSize="12sp"
                android:textColor="@color/text_secondary_dark"/>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvReportDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Report description goes here..."
        android:textSize="14sp"
        android:textColor="@color/text_secondary_dark"
        android:layout_marginBottom="12dp"/>

    <!-- Status Badge -->
    <TextView
        android:id="@+id/tvReportStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✅ Submitted"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/safe_green"
        android:background="@drawable/status_safe"
        android:paddingVertical="6dp"
        android:paddingHorizontal="12dp"/>

</LinearLayout>
