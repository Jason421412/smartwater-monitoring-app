<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Premium Dark Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_premium_dark"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Premium Gradient Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="@drawable/gradient_header"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:elevation="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white"
                android:contentDescription="Back"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Post"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Original Post Card - Glass -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_strong"
                    android:padding="20dp">

                    <!-- Author Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <!-- Avatar with Glow -->
                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp">

                            <View
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:layout_gravity="center"
                                android:background="@drawable/glow_effect"/>

                            <LinearLayout
                                android:layout_width="52dp"
                                android:layout_height="52dp"
                                android:layout_gravity="center"
                                android:background="@drawable/avatar_circle"
                                android:gravity="center">

                                <ImageView
                                    android:id="@+id/ivProfilePic"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:src="@android:drawable/ic_menu_myplaces"
                                    app:tint="@color/primary"/>

                            </LinearLayout>

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAuthorName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Author Name"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary_dark"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@android:drawable/ic_menu_mylocation"
                                    app:tint="@color/primary"
                                    android:layout_marginEnd="4dp"/>

                                <TextView
                                    android:id="@+id/tvLocation"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Location"
                                    android:textSize="13sp"
                                    android:textColor="@color/text_secondary_dark"/>

                            </LinearLayout>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvTimestamp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2h"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"/>

                    </LinearLayout>

                    <!-- Post Content -->
                    <TextView
                        android:id="@+id/tvContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Post content goes here..."
                        android:textSize="16sp"
                        android:textColor="@color/text_primary_dark"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Sensor Data Badge -->
                    <LinearLayout
                        android:id="@+id/llSensorData"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/status_safe"
                        android:padding="12dp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_compass"
                            app:tint="@color/safe_green"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/tvSensorData"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="pH: 7.2 | Temp: 25.5°C"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/safe_green"/>

                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="8dp">

                        <TextView
                            android:id="@+id/tvReplyCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="💬 12 Replies"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"/>

                        <TextView
                            android:id="@+id/tvLikeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭐ 45"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_pink"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Replies Section Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬 Replies"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"
                    android:layout_marginBottom="12dp"/>

                <!-- Replies List Container -->
                <LinearLayout
                    android:id="@+id/llRepliesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

                <!-- Empty State -->
                <TextView
                    android:id="@+id/tvNoReplies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No replies yet. Be the first to reply! 💬"
                    android:textSize="14sp"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:background="@drawable/card_glass"
                    android:padding="24dp"
                    android:visibility="gone"/>

            </LinearLayout>

        </ScrollView>

        <!-- Reply Input Bar - Glass -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_glass_strong"
            android:padding="12dp"
            android:elevation="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etReplyInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Write a reply..."
                android:background="@drawable/card_glass"
                android:padding="14dp"
                android:textSize="14sp"
                android:textColor="@color/text_primary_dark"
                android:textColorHint="@color/text_hint"
                android:maxLines="3"
                android:inputType="textMultiLine"/>

            <ImageButton
                android:id="@+id/btnSendReply"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/btn_gradient"
                android:src="@android:drawable/ic_menu_send"
                android:padding="14dp"
                app:tint="@android:color/white"
                android:contentDescription="Send Reply"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
