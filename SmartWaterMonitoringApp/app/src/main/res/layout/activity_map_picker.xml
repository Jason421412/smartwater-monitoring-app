<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Google Map Fragment -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Centered Pin Marker with Glow -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:translationY="-24dp">

        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@drawable/glow_effect"/>

        <ImageView
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/polluted_red"
            android:contentDescription="Map Pin"/>

    </FrameLayout>

    <!-- Top Address Card - Glass -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_gravity="top"
        android:background="@drawable/card_glass_strong"
        android:padding="20dp"
        android:gravity="center"
        android:elevation="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="@color/primary"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvSelectedAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Move map to select location..."
            android:textSize="15sp"
            android:textColor="@color/text_primary_dark"
            android:gravity="start"/>

    </LinearLayout>

    <!-- Bottom Container for Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingBottom="100dp"
        android:paddingHorizontal="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmLocation"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Confirm Location"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            app:icon="@android:drawable/ic_menu_mylocation"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/primary"
            android:elevation="8dp"/>

    </LinearLayout>

</FrameLayout>

