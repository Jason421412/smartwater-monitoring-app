<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="@drawable/card_glass"
    android:layout_marginBottom="10dp">

    <!-- Location Icon with Glow -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp">

        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/glow_effect"/>

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:background="@drawable/avatar_circle"
            android:gravity="center">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:tint="@color/primary"/>

        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSessionTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2024-12-15 10:30 AM"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_dark"/>

        <TextView
            android:id="@+id/tvSessionLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 37.7749°N, 122.4194°W"
            android:textSize="13sp"
            android:textColor="@color/text_secondary_dark"/>

        <TextView
            android:id="@+id/tvSessionData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 pH: 7.2 | 🌡️ Temp: 25.5°C"
            android:textSize="13sp"
            android:textColor="@color/primary"/>

    </LinearLayout>

    <!-- Status Badge -->
    <TextView
        android:id="@+id/tvSessionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SAFE"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/safe_green"
        android:background="@drawable/status_safe"
        android:paddingVertical="6dp"
        android:paddingHorizontal="12dp"/>

</LinearLayout>
