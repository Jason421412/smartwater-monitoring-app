<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0A1628"
                android:centerColor="#1A2940"
                android:endColor="#0F1C2E"/>
        </shape>
    </item>
    <!-- Top accent glow -->
    <item android:top="-200dp" android:left="-100dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#4000D9FF"
                android:endColor="#00000000"/>
            <size android:width="400dp" android:height="400dp"/>
        </shape>
    </item>
    <!-- Bottom right accent -->
    <item android:bottom="-150dp" android:right="-150dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="250dp"
                android:startColor="#406C63FF"
                android:endColor="#00000000"/>
            <size android:width="350dp" android:height="350dp"/>
        </shape>
    </item>
</layer-list>
