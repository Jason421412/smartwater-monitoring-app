<?xml version="1.0" encoding="utf-8"?>
<!-- ✨ Liquid Glass Card Background - Frosted translucent effect -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Outer glow effect -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="#1000D4FF"/>
        </shape>
    </item>
    
    <!-- Main glass surface -->
    <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#25FFFFFF"
                android:centerColor="#18FFFFFF"
                android:endColor="#10FFFFFF"/>
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF"/>
        </shape>
    </item>
    
    <!-- Inner highlight (top edge) -->
    <item android:top="2dp" android:left="8dp" android:right="8dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="22dp" android:topRightRadius="22dp"/>
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00FFFFFF"
                android:endColor="#15FFFFFF"/>
            <size android:height="2dp"/>
        </shape>
    </item>
    
</layer-list>
